# Frontend (Vite)
# Copy to `.env` in the repo root and fill in your Firebase web app values.

# Backend API base URL for local development
VITE_API_URL=http://localhost:3001/api

# Backend-only Groq config for Yumi chatbot.
# Put these in the backend runtime environment, not in frontend Vite vars.
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant

# Optional: frontend Cloudinary cloud name if you want to override the default cloud
VITE_CLOUDINARY_CLOUD_NAME=div8klfkc

# Firebase web app config
# Optional for browse-only local development. Leave these blank to run in
# local-only mode with auth/profile/cloud-sync features disabled.
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
