# Backend
# Copy to `backend/.env` and adjust values as needed.

# Server
PORT=3001

# Public API base URL used by some scraper flows
API_URL=http://localhost:3001/api

# Optional: Fanart.tv API key for anime logos/artwork enrichment
FANART_API_KEY=

# Optional: Upstash Redis for shared caching/locks
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: disable the scraper warmer in local/dev environments
DISABLE_SCRAPER_WARMER=true

# Optional: Groq-powered Yumi recommendation chatbot
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
