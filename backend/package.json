{
    "name": "yorumi-backend",
    "version": "1.0.0",
    "description": "Backend for Yorumi",
    "main": "dist/index.js",
    "bin": {
        "yorumi-cli": "dist/cli.js"
    },
    "scripts": {
        "start": "node dist/index.js",
        "predev": "npx -y kill-port 3001",
        "dev": "nodemon --exec tsx src/index.ts",
        "cli": "tsx src/cli.ts",
        "build": "tsc",
        "migrate:mappings:dry": "tsx scripts/migrate-anilist-mappings.ts",
        "migrate:mappings": "tsx scripts/migrate-anilist-mappings.ts --apply"
    },
    "dependencies": {
        "@consumet/extensions": "^1.8.8",
        "@sparticuz/chromium": "^143.0.4",
        "@types/cheerio": "^0.22.35",
        "@upstash/redis": "^1.36.1",
        "aniwatch": "^2.27.9",
        "axios": "^1.6.0",
        "cheerio": "^1.1.2",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "fuse.js": "^7.1.0",
        "graphql-request": "^7.4.0",
        "hianime": "^1.5.1",
        "hianime-scraper": "^3.5.0",
        "puppeteer-extra": "^3.3.6",
        "puppeteer-extra-plugin-stealth": "^2.11.2"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.10.0",
        "nodemon": "^3.0.1",
        "puppeteer": "^24.35.0",
        "ts-node": "^1.7.1",
        "tsx": "^4.21.0",
        "typescript": "^5.3.2"
    }
}
